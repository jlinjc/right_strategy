# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Environments
.env
.venv
env/
venv/
ENV/

# Data and Logs
*.json
Web_Dashboard/charts/
Web_Dashboard/*.json
*.png
*.jpg
*.log

# OS generated files
.DS_Store
Thumbs.db
*.csv

# Large data caches — NEVER commit (alpha/cache is 120MB+ of pkl)
*.pkl
alpha/cache/

# ...but DO commit the dashboard's JSON so GitHub Pages can serve it
!Web_Dashboard/*.json
